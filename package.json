{
    "name": "grafana-yamcs-jaops",
    "version": "1.0.0",
    "scripts": {
        "build": "webpack -c ./webpack.config.ts --env production",
        "dev": "webpack -w -c ./webpack.config.ts --env development",
        "test": "jest --watch --onlyChanged",
        "test:backend": "go test ./pkg/...",
        "test:ci": "jest --passWithNoTests --maxWorkers 4",
        "typecheck": "tsc --noEmit",
        "lint": "eslint --cache .",
        "lint:fix": "pnpm run lint --fix && prettier --write --list-different .",
        "e2e": "playwright test",
        "server": "docker compose up --build",
        "server:dev": "DEVELOPMENT=true docker compose up --build",
        "server:localhost": "docker compose up --build",
        "server:nginx": "docker compose -f docker-compose.yaml -f .config/docker-compose-nginx.yaml up --build",
        "sign": "npx --yes @grafana/sign-plugin@latest"
    },
    "author": "Jaops",
    "license": "MIT",
    "devDependencies": {
        "@grafana/eslint-config": "^10.0.0",
        "@grafana/plugin-e2e": "^3.9.1",
        "@grafana/tsconfig": "^2.2.0",
        "@playwright/test": "^1.61.0",
        "@stylistic/eslint-plugin-ts": "^4.4.1",
        "@swc/core": "^1.15.41",
        "@swc/helpers": "^0.5.23",
        "@swc/jest": "^0.2.39",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@types/jest": "^30.0.0",
        "@types/node": "^26.0.0",
        "@types/react": "18",
        "@types/react-dom": "18",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.61.1",
        "@typescript-eslint/typescript-estree": "^8.61.1",
        "@typescript-eslint/utils": "^8.61.1",
        "copy-webpack-plugin": "^14.0.0",
        "css-loader": "^7.1.4",
        "eslint": "^9.30.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^63.0.6",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-webpack-plugin": "^6.0.0",
        "fork-ts-checker-webpack-plugin": "^9.1.0",
        "glob": "^13.0.6",
        "identity-obj-proxy": "3.0.0",
        "imports-loader": "^5.0.0",
        "jest": "^30.4.2",
        "jest-environment-jsdom": "^30.4.1",
        "prettier": "^3.8.4",
        "replace-in-file-webpack-plugin": "^1.0.6",
        "sass": "1.101.0",
        "sass-loader": "17.0.0",
        "semver": "^7.8.4",
        "style-loader": "4.0.0",
        "swc-loader": "^0.2.7",
        "terser-webpack-plugin": "^5.6.1",
        "ts-node": "^10.9.2",
        "typescript": "5.9.2",
        "webpack": "^5.107.2",
        "webpack-cli": "^7.0.3",
        "webpack-livereload-plugin": "^3.0.2",
        "webpack-merge": "^6.0.1",
        "webpack-subresource-integrity": "5.2.0-rc.1",
        "webpack-virtual-modules": "^0.6.2"
    },
    "engines": {
        "node": ">=22"
    },
    "dependencies": {
        "@emotion/css": "11.13.5",
        "@grafana/data": "^13.0.2",
        "@grafana/runtime": "^13.0.2",
        "@grafana/schema": "^13.0.2",
        "@grafana/ui": "^13.0.2",
        "@testing-library/user-event": "^14.6.1",
        "date-fns": "^4.4.0",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "react-router-dom": "^7.18.0",
        "rxjs": "7.8.2"
    },
    "packageManager": "pnpm@10.28.1",
    "pnpm": {
        "overrides": {
            "@babel/runtime@<7.26.10": ">=7.26.10",
            "@babel/helpers@<7.26.10": ">=7.26.10",
            "brace-expansion@>=1.0.0 <=1.1.11": "1.1.12",
            "brace-expansion@>=2.0.0 <=2.0.1": "2.0.2",
            "form-data@<4.0.2": ">=4.0.2",
            "@remix-run/router@<1.23.2": ">=1.23.2",
            "glob@<10.5.0": ">=10.5.0",
            "qs@<6.14.1": ">=6.14.1",
            "brace-expansion@<1.1.13": ">=1.1.13",
            "dompurify@<=3.3.3": ">=3.4.0",
