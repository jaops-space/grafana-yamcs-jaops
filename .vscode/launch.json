{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Delve: Attach to remote headless",
            "type": "go",
            "request": "attach",
            "mode": "remote",
            "debugAdapter": "legacy",
            "host": "127.0.0.1",
            "port": 2345,
            "cwd": "${workspaceFolder}",
            "remotePath": "/root/jaops-yamcs-app",
            "substitutePath": [
                {
                    "from": "${workspaceFolder}",
                    "to": "/root/jaops-yamcs-app"
                }
            ],
            "showLog": true,
            "logOutput": "dap",
            "trace": "verbose"
        }
    ]
}